# FactoryOS — Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# Backend URL used server-side for the /api/* rewrite proxy.
# Development: http://localhost:8000
# Docker Compose: http://backend:8000 (service name from docker-compose.yml)
BACKEND_INTERNAL_URL=http://localhost:8000

# Node environment (set automatically by Next.js — do not override)
# NODE_ENV=development
