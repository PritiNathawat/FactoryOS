# ============================================================
# FactoryOS — Environment Variables
# ============================================================
# Copy this file to backend/.env and fill in your values.
#
#   cp .env.example backend/.env
#
# Variables without defaults MUST be set before running.
# Variables with defaults are optional.
# ============================================================

# ─── Google AI (Gemini) ─────────────────────────────────────
# Required for real AI agent responses.
# Without this key, the AI Platform runs in MOCK MODE —
# all agent responses return realistic simulated data.
#
# Obtain your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini model to use. gemini-2.0-flash is recommended (fast, cost-effective).
# Other options: gemini-1.5-pro, gemini-2.0-flash-thinking-exp
GEMINI_MODEL=gemini-2.0-flash

# ─── Application ────────────────────────────────────────────
# Environment: development | staging | production
ENVIRONMENT=development

# Set to INFO in production, DEBUG for local development
LOG_LEVEL=INFO

# ─── Database ───────────────────────────────────────────────
# Default: SQLite (zero infrastructure, development-ready)
# For PostgreSQL, change to: postgresql+asyncpg://user:pass@host:5432/factoryos
DATABASE_URL=sqlite+aiosqlite:///./factoryos.db

# ─── CORS ───────────────────────────────────────────────────
# Allowed origins for the FastAPI CORS middleware.
# In production, set this to your actual frontend domain.
# CORS_ORIGINS=https://your-domain.com

# ─── Frontend (Next.js) ─────────────────────────────────────
# Internal URL used by Next.js to proxy /api/* requests to the backend.
# During development: http://localhost:8000
# Inside Docker Compose: http://backend:8000
BACKEND_INTERNAL_URL=http://localhost:8000
